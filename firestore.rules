rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Catch-all default deny (Zero-Trust)
    match /{document=**} {
      allow read, write: if false;
    }

    // Checking if the user is authenticated in Firebase
    function isSignedIn() {
      return request.auth != null;
    }

    // Checking if the user has a verified email address
    function isEmailVerified() {
      return isSignedIn() && (request.auth.token.email_verified == true);
    }

    // Checking administrative access by verified developer email
    function isAdmin() {
      return isSignedIn() && (request.auth.token.email == 'rohtjan4@gmail.com');
    }

    // Config: Examination settings and questions
    match /config/activeExam {
      // Publicly readable so students can see instructions, settings & questions
      allow read: if true;
      // Allow write for verified admin or guest passcode admin (works with guest passcode admins and offline fallbacks)
      allow write: if true;
    }

    // Results: Student submissions
    match /results/{resultId} {
      // Allow read and write for multi-device realtime synchronization (works with guest passcode admins and offline fallbacks)
      allow read, write: if true;
    }

    // Usernames: Map for username-to-email login
    match /usernames/{username} {
      // Allows individual lookup for login and pwd resets (Prevents full-list queries)
      allow get: if true;
      // Newly registering users can reserve their unique username mapping
      allow create: if isSignedIn();
      // Restrict edits/deletions of mapped usernames to admin only
      allow update, delete: if isAdmin();
    }
  }
}
